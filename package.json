{
  "name": "everest",
  "private": true,
  "version": "0.0.1",
  "description": "SystemRDL desktop editor",
  "author": "Lawjay Lee",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:web": "vite build",
    "tauri:dev": "bun tauri dev",
    "tauri:build": "bun tauri build",
    "tauri:build:appimage": "NO_STRIP=true bun tauri build --bundles appimage",
    "tauri:build:win": "bun tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:deb": "bun tauri build --bundles deb",
    "sidecar:build": "bun scripts/build-rdl-parser-sidecar.ts",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@internationalized/date": "^3.12.2",
    "@lucide/svelte": "^1.23.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "eslint-plugin-tailwindcss": "^4.0.6",
    "formsnap": "^2.0.1",
    "globals": "^17.7.0",
    "layerchart": "2.0.0-next.48",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "svelte-eslint-parser": "^1.8.0",
    "svelte-sonner": "^1.1.1",
    "sveltekit-superforms": "^2.30.2",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tanstack/hotkeys": "^0.8.0",
    "@tanstack/svelte-hotkeys": "^0.10.0",
    "@tauri-apps/api": "^2.11.1",
    "effect": "^3.21.4",
    "flexsearch": "^0.8.212"
  }
}
