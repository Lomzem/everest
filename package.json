{
  "name": "basecamp",
  "private": true,
  "version": "0.0.1",
  "description": "SystemRDL desktop editor",
  "author": "Lawjay Lee",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite dev",
    "build:web": "vite build",
    "tauri:dev": "bun tauri dev",
    "tauri:build": "bun tauri build",
    "tauri:build:win": "bun tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:deb": "bun tauri build --bundles deb",
    "sidecar:build": "bun scripts/build-rdl-parser-sidecar.ts",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k \"bun run dev --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 bun --bun ./node_modules/@electron-forge/cli/dist/electron-forge-start.js\"",
    "build": "bun run build:web && bun run electron:compile",
    "package": "bun run build && bun --bun ./node_modules/@electron-forge/cli/dist/electron-forge-package.js",
    "make": "bun run build && bun --bun ./node_modules/@electron-forge/cli/dist/electron-forge-make.js",
    "make:win": "bun run build && bun --bun ./node_modules/@electron-forge/cli/dist/electron-forge-make.js --platform win32 --arch x64",
    "make:deb": "bun run build && bun --bun ./node_modules/@electron-forge/cli/dist/electron-forge-make.js --platform linux --arch x64 --targets deb",
    "make:rpm": "bun run build && bun --bun ./node_modules/@electron-forge/cli/dist/electron-forge-make.js --platform linux --arch x64 --targets rpm",
    "make:appimage": "bun run build && electron-builder --linux AppImage --x64",
    "make:win:portable": "bun run build && bun --bun ./node_modules/electron-builder/cli.js --config electron-builder.win.yml --win portable --x64",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.23.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/table-core": "^8.21.3",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.0",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "eslint-plugin-tailwindcss": "^4.0.6",
    "formsnap": "^2.0.1",
    "globals": "^17.7.0",
    "layerchart": "2.0.0-next.48",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.8.0",
    "svelte-sonner": "^1.1.0",
    "sveltekit-superforms": "^2.30.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "effect": "^3.21.4",
    "flexsearch": "^0.8.212"
  }
}
